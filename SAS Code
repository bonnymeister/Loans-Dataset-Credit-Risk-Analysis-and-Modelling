Proc Sql NOPRINT;create table Report_clust_&n. as
			 		   Select &VarX. as Var,
					    Cluster,
						Default_status,
					   	Count(* )   as Total,
						  sum(Default_status=1)  	as Total_Bads, 
			              sum(Default_status=0 )	as Total_Goods
					from  clust_&n.
;
Quit;

Proc Sql NOPRINT;create table SUM_Report_Final_&n. as
			 		   Select Cluster,
					   Total,
					   Total_Bads,
					   Total_Goods,
					   	Count(* )   as N_Class,
						Min(Var) as Min , 
						  Max(Var) as Max , 
						  sum(Default_status=1)/Total_Bads*100  as PCT_B   format=5.2 ,
                          sum(Default_status=0)/Total_Goods*100  as PCT_G   format=5.2,
			 		      sum(Default_status=1)  	as Bads, 
			              sum(Default_status=0 )	as Goods,
						  log((sum(Default_status=0)/Total_Goods)/(sum(Default_status=1)/Total_Bads))  as WOE,
                         (calculated PCT_G - calculated PCT_B)*(calculated Woe)   as IVi,
                         (calculated N_Class)/total*100 as pct_obs
					from   Report_clust_&n.
					    Group by Cluster
   						;
					Quit;
